{
  "name": "reminder-nurse",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server/dist/server.js",
    "dev": "concurrently -k -c auto \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "postinstall": "cd client && npm i && cd ../server && npm i",
    "build": "cd client && npm run build && cd ../server && npm run build",
    "generate": "cd server && npm run generate",
    "seed": "cd server && npm run seed",
    "lint": "cd client && npm run lint",
    "prettier": "npx prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IqbalAhmadi/mern-project.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/IqbalAhmadi/mern-project/issues"
  },
  "homepage": "https://github.com/IqbalAhmadi/mern-project#readme",
  "devDependencies": {
    "concurrently": "^9.2.0",
    "prettier": "^3.6.0"
  },
  "prettier": {
    "singleQuote": true
  }
}
