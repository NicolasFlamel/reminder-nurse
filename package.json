{
  "name": "reminder-nurse",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server/dist/server.js",
    "dev": "concurrently -k -c auto \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:host": "concurrently -k -c auto \"npm:dev:client:host\" \"npm:dev:server\"",
    "dev:client:host": "cd client && npm run dev:host",
    "postinstall": "cd client && npm i && cd ../server && npm i",
    "build": "cd client && npm run build && cd ../server && npm run build",
    "generate": "cd server && npm run generate",
    "seed": "cd server && npm run seed",
    "lint": "cd client && npm run lint",
    "test": "cd client && npm run test && cd ../server && npm run test",
    "docker:up": "docker compose -p reminder-nurse-v2 up -d",
    "docker:down": "docker compose -p reminder-nurse-v2 down",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IqbalAhmadi/mern-project.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/IqbalAhmadi/mern-project/issues"
  },
  "homepage": "https://github.com/IqbalAhmadi/mern-project#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
